{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Fresh desktop app",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:allow-open",
    "opener:allow-open-path",
    "opener:allow-open-url",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "deep-link:default"
  ]
}

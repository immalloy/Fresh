{
  "name": "fresh",
  "version": "0.1.0",
  "description": "Fresh desktop launcher built with React + Tauri 2",
  "license": "GPL-3.0",
  "author": {
    "name": "ImMalloy",
    "email": "henrydraft.jpeg@gmail.com"
  },
  "homepage": "https://github.com/Crew-Awesome/Fresh",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test:windows": "scripts\\test-windows.bat",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "build:renderer": "vite build",
    "build:desktop:linux": "tauri build --bundles appimage",
    "build:desktop:win": "tauri build --bundles nsis",
    "build:desktop:mac": "tauri build --bundles dmg"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-deep-link": "^2.4.3",
    "@tauri-apps/plugin-dialog": "^2.4.1",
    "@tauri-apps/plugin-opener": "^2.4.1",
    "@tauri-apps/plugin-updater": "^2.9.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.1",
    "lucide-react": "^0.555.0",
    "motion": "^12.23.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@tauri-apps/cli": "^2.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.7",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^4.0.7"
  }
}
